DASHSCOPE_API_KEY=your_api_key_here

# USE_REDIS=true 时启用 AgentScope 完整服务（agents、sessions、chat、MCP 等）
USE_REDIS=false

# Redis（USE_REDIS=true 时需要）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Optional: 高德 MCP（需申请 AMAP_API_KEY）
# AMAP_API_KEY=

# Server
# HOST=0.0.0.0
# PORT=8100
# WORKSPACES_DIR=./workspaces
# CORS_ALLOW_ORIGINS=*
